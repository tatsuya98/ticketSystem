{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build C++ Project",
            "command": "g++",
            "args": [
                "-std=c++23",
                "-Wall",
                "-g",
                "${workspaceFolder}/*.cpp",
                "-o",
                "${workspaceFolder}/output"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}